# ========================
# FRONTEND ACTIVO (React)
# ========================
# Variables realmente usadas por la app actual.

# Opciones:
# - fake: usa fakeProvider con localStorage y auth demo local.
# - supabase: usa Supabase Auth/DB/RPC para catalogos, solicitudes e historial.
REACT_APP_DATA_PROVIDER=fake

# Opciones:
# - true: habilita login demo local. Util cuando REACT_APP_DATA_PROVIDER=fake.
# - false: deshabilita login demo local.
REACT_APP_ENABLE_DEMO_AUTH=true

# Opciones comunes:
# - development
# - staging
# - production
REACT_APP_APP_ENV=development

# Valor esperado:
# - URL base HTTPS del proyecto Supabase.
# - Ejemplo: https://tu-project-ref.supabase.co
REACT_APP_SUPABASE_URL=

# Valor esperado:
# - anon key publica del proyecto Supabase.
# - No usar service role en el frontend.
REACT_APP_SUPABASE_ANON_KEY=

# ========================
# LEGACY / OPCIONAL
# ========================
# El flujo interactivo actual ya no usa n8n ni REACT_APP_API_BASE_URL.
# Deja estas variables solo si vas a reactivar el flujo legado de export-start
# o alguna integracion historica basada en n8n fuera del frontend actual.

# Valor esperado:
# - URL base del webhook legado de n8n.
# - Ejemplo local: http://localhost:5678/webhook
# REACT_APP_API_BASE_URL=http://localhost:5678/webhook

# Valor esperado:
# - API key cliente para el flujo legado con n8n.
# REACT_APP_API_KEY=tigo-pop-key

# Opciones comunes:
# - America/Bogota
# TZ=America/Bogota

# Opciones:
# - true
# - false
# N8N_BASIC_AUTH_ACTIVE=true

# Valor esperado:
# - Usuario de acceso a la UI de n8n.
# N8N_BASIC_AUTH_USER=admin

# Valor esperado:
# - Password de acceso a la UI de n8n.
# N8N_BASIC_AUTH_PASSWORD=

# Valor esperado:
# - Clave larga de cifrado interna para n8n.
# N8N_ENCRYPTION_KEY=

# Valor esperado:
# - Host donde corre n8n.
# - Ejemplo local: localhost
# N8N_HOST=localhost

# Valor esperado:
# - Puerto expuesto por n8n.
# - Ejemplo local: 5678
# N8N_PORT=5678

# Opciones comunes:
# - http
# - https
# N8N_PROTOCOL=http

# Valor esperado:
# - Lista separada por comas de API keys validas para webhooks legacy.
# VALID_API_KEYS=tigo-pop-key

# Valor esperado:
# - project ref de Supabase.
# - Ejemplo: ftftlekcgthgrbmvoajd
# SUPABASE_PROJECT_ID=

# Valor esperado:
# - Service role de Supabase.
# - Solo backend o funciones seguras, nunca frontend.
# SUPABASE_SERVICE_ROLE=

# Valor esperado:
# - Alias alterno si alguna integracion legacy espera esta clave.
# SUPABASE_SERVICE_ROLE_KEY=

# Valor esperado:
# - URL del webhook de export legacy en n8n.
# N8N_EXPORT_WEBHOOK_URL=

# Valor esperado:
# - Token interno compartido entre Edge Function legacy y n8n.
# N8N_INTERNAL_TOKEN=
